{
  "name": "pin-proshop",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "deploy": "npx expo export --platform web && npx firebase-tools deploy --only hosting",
    "git": "git add . && git commit -m \"update\" && git push",
    "ship": "npx expo export --platform web && npx firebase-tools deploy --only hosting && git add . && git commit -m \"deploy\" && git push"
  },
  "dependencies": {
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.5",
    "expo": "~55.0.6",
    "expo-image": "~55.0.6",
    "expo-status-bar": "~55.0.4",
    "firebase": "^12.10.0",
    "firebase-tools": "^15.13.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0"
  },
  "private": true
}
